{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "otto-bot",
  "main": "./src/index.ts",
  "compatibility_date": "2025-09-27",
  "assets": {
    "run_worker_first": true,
  },
  "keep_vars": true,
  "kv_namespaces": [
    {
      "binding": "KV",
    },
  ],
  "d1_databases": [
    {
      "binding": "DB",
    },
  ],
  "triggers": {
    "crons": ["0 0 * * sun"],
  },
}
